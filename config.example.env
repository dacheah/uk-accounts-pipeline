# 1. Copy this file and rename the copy to:  secrets.env
# 2. Fill in the values below (no quotes, no spaces around the = sign).
# 3. Save. The file "secrets.env" is gitignored, so it is never published.

# Your Companies House API key (used by Product 2 + spot checks):
CH_API_KEY=your-companies-house-api-key-here

# Where to store downloads + datasets. Point this at your big drive so large files
# stay off C:. Example (Windows):
CH_DATA_DIR=D:\UKHouseData
